---
import BaseLayout from "../../layouts/BaseLayout.astro";
import OrderForm from "../../components/OrderForm.astro";
---

<BaseLayout lang="en" title="Order">
  <OrderForm
    lang="en"
    labels={{
      title: "Online Ordering",
      orderInfoLine1: "Orders are prepared weekly every Monday.",
      orderInfoLine2: "Pickup is available at [location] during [times].",
      orderInfoLine3:
        "Orders received after [cutoff] will be prepared the following week.",
      name: "Name",
      email: "Email",
      phone: "Phone",
      comments: "Use this space for special requests or order notes:",
      products: "Products",
      submit: "Submit",
      muffinsNote: "Sold in sets of 6",
      successTitle: "Order received",

      orderSummaryLabel: "Your order",

      paymentTitle: "Payment",
      paymentEmail: "email@email.com",

      paymentLine1: "Please send payment by e-transfer to:",
      paymentLine2: "Include your name with the transfer.",
      paymentLine3: "Your order will be prepared once payment is received.",
    }}
  />
</BaseLayout>
