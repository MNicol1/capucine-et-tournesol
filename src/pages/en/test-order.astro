---

---

<h1>Test Order</h1>

<form id="order-form">
  <input name="name" placeholder="Name" required />
  <input name="email" type="email" placeholder="Email" required />
  <input name="phone" placeholder="Phone" />

  <h3>Products</h3>
  <div id="products"></div>

  <br />
  <textarea name="comments" placeholder="Comments"></textarea>

  <br /><br />
  <button type="submit">Submit</button>
</form>

<script>
  // @ts-nocheck

  const PRODUCTS = [
    { key: "tout_ble", name: "Tout blé", price: 4.75 },
    { key: "grains_12", name: "12 grains", price: 5.25 },
    { key: "proteine", name: "Protéine", price: 5.25 },
    { key: "raisins", name: "Raisins", price: 5.75 },
    { key: "ble_mais", name: "Blé et maïs", price: 5.25 },
    { key: "son_avoine_lin", name: "Son d’avoine et lin", price: 5.75 },
    { key: "ble_sesame", name: "Blé sésame", price: 5.75 },
    { key: "ble_tournesol", name: "Blé tournesol", price: 5.75 },
    { key: "miche_ble", name: "Miche de blé", price: 7.6 },
    { key: "seigle_vendredi", name: "Seigle", price: 6.75 },
    { key: "grains_16", name: "16 grains", price: 5.75 },
    { key: "kamut", name: "Kamut", price: 7.6 },
    { key: "epeautre", name: "Épeautre", price: 7.6 },
    { key: "reine_elisabeth", name: "Reine élisabeth", price: 9.75 },
    { key: "noisettes_chocolat", name: "Noisettes et chocolat", price: 9.75 },
    { key: "canneberges_citron", name: "Canneberges et citron", price: 9.25 },
    { key: "ananas_gingembre", name: "Ananas et gingembre", price: 9.25 },
    { key: "carottes", name: "Carottes", price: 8.5 },
    { key: "bananes_cacao", name: "Bananes et cacao", price: 8.5 },
    { key: "pommes_cannelle", name: "Pommes et cannelle", price: 8.5 },
  ];

  // Render product inputs
  const container = document.getElementById("products");

  PRODUCTS.forEach((p) => {
    const wrapper = document.createElement("label");

    wrapper.innerHTML = `
      ${p.name} ($${p.price})
      <input type="number" name="${p.key}_qty" min="0" value="0" />
    `;

    container.appendChild(wrapper);
    container.appendChild(document.createElement("br"));
  });

  const form = document.getElementById("order-form");

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      const items = [];

      PRODUCTS.forEach((product) => {
        const qty = Number(data[`${product.key}_qty`] || 0);

        if (qty > 0) {
          items.push({
            name: product.name, // FR name only for backend
            qty,
            price: product.price,
          });
        }
      });

      // Items string (must match Sheets parsing)
      const itemsDisplay = items
        .map((item) => `${item.name} (x${item.qty})`)
        .join(", ");

      // Total (number, not string)
      const total = items.reduce((sum, item) => {
        return sum + item.qty * item.price;
      }, 0);

      const payload = {
        name: data.name,
        email: data.email,
        phone: data.phone,
        items: itemsDisplay,
        total,
        comments: data.comments,
      };

      try {
        const res = await fetch("/.netlify/functions/order", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const json = await res.json();
        console.log("Response:", json);
      } catch (err) {
        console.error("Error:", err);
      }
    });
  }
</script>
