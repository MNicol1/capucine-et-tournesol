        "Utilisez cet espace pour les demandes spéciales ou notes de commande :",
      products: "Produits",
      submit: "Envoyer",
      muffinsNote: "Sold in packs of 6",

      successTitle: "Commande reçue",

      orderSummaryLabel: "Votre commande",

      paymentTitle: "Paiement",
      paymentEmail: "email@email.com",

      paymentLine1: "Veuillez envoyer le paiement par virement Interac à :",
      paymentLine2: "Inclure votre nom avec le virement.",
      paymentLine3: "Votre commande sera préparée après réception du paiement.",
